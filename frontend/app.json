{
  "expo": {
    "name": "QuickGig",
    "slug": "quickgig",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "quickgig",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "primaryColor": "#FF6B6B",
    "description": "QuickGig is a neighborhood marketplace for posting and accepting small local jobs — lawn care, cleaning, handyman, errands, moving help, and more.",
    "ios": {
      "bundleIdentifier": "quickgig.app",
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": "AIzaSyDiuBkaCunUpvH9HwyLX7_hejVO0l9bW5c"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Find gigs near you and show distance.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Find gigs near you and show distance.",
        "NSPhotoLibraryUsageDescription": "Attach photos to job posts.",
        "NSPhotoLibraryAddUsageDescription": "Save job photos to your library.",
        "NSCameraUsageDescription": "Take photos for job posts and ID checks.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "quickgig.app",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDiuBkaCunUpvH9HwyLX7_hejVO0l9bW5c"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FDFBF7"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "CAMERA",
        "POST_NOTIFICATIONS",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#FDFBF7"
        }
      ],
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Find gigs near you and show distance."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Attach photos to job posts.",
          "cameraPermission": "Take photos for job posts and ID checks."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#FF6B6B",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supportEmail": "support@quickgig.app",
      "website": "https://quickgig.app"
    }
  }
}
